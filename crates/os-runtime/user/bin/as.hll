; In-VM RV64I assembler: `as <src> <out>` two-pass assembles a static ELF64 (one
; PT_LOAD at USER_CODE_BASE) for sys_exec. Subset, directives, encodings, NOP quirk: OS spec 10.3.

external console_write:   (str: u8*)
external console_writeln: (str: u8*)

; Userspace syscalls and C-string helpers (defined in the hosted stdlib).
external sc_open:      (path: u8*, flags: u64) -> i64
external sc_read:      (fd: i64, buf: u8*, offset: u64, len: u64) -> i64
external sc_write:     (fd: i64, buf: u8*, len: u64) -> i64
external sc_ftruncate: (fd: i64, len: u64) -> i64
external sc_close:     (fd: i64)
external sc_exit:      (code: i64)
external cstr_eq:      (a: u8*, b: u8*) -> i64
external cstr_len:     (s: u8*) -> u64

; ET_REL object serializer, split into as_object.hll and linked by the host
; toolchain. Reads the shared assembler state (out/code/data/labels/relocs).
external write_object: () -> u64

; Page the kernel maps with this program's argument string. Matches USER_ARG_BASE.
const ARG_BASE = 0x7FF00000
; Virtual base the kernel maps user code at; the ELF links e_entry/p_vaddr here.
const USER_CODE_BASE = 0x40000000
; ELF header region size; the page-aligned PT_LOAD payload (flat binary) starts here.
const HDR = 4096
; Bytes of NOP padding between the text and data regions (the M-mode halt quirk).
const PAD = 32

; Source text, assembled code, and the ELF output image. The big buffers are
; heap-allocated once at startup (see main / as_object's lazy init).
src: u8* = null
src_len: u64 = 0
code: u8* = null
code_len: u64 = 0
; Data section bytes, appended after the text + NOP pad in the final image.
data: u8* = null
data_len: u64 = 0
; Current section: 0 = text, 1 = data. Switched by .text/.data directives.
cur_sec: i64 = 0
; Final text size after pass 1; data labels resolve to text_total + PAD + offset.
text_total: i64 = 0
; Output image: ELF header + program header in the first page, payload from HDR on.
; Also reused as the ET_REL object image in object mode (text/data/relocs/symtab).
out: u8* = null

; Label / Reloc record layouts come from the shared as_layout.hll header.

; Label table; resolve_labels() rewrites data addresses to absolute positions.
labels: Label* = null
lbl_count: i64 = 0

; Token table for one line: up to 6 tokens, 24 bytes each (one lexeme per slot).
tokbuf: u8* = null
ntok: i64 = 0

; Set once on any assembly error so main can abort with a non-zero exit.
err_flag: i64 = 0

; --- Object (ET_REL) mode ---
; 1 when the output path ends in ".o": emit a relocatable object for ld.hll
; instead of a runnable ET_EXEC. In object mode call/jal to an undefined symbol
; and every la become relocations rather than locally-resolved or errors.
obj_mode: i64 = 0

; Names exported via `.globl`, packed 16 bytes each (symtab STB_GLOBAL bind).
glbl_names: u8* = null
glbl_count: i64 = 0

relocs: Reloc* = null
nreloc: i64 = 0

; Pointer to token i in the line token table.
tok_at: (i: i64) -> u8* {
    return tokbuf[0] + (i as u64) * 24
}

; Report an assembly error with a one-line message and remember the failure.
fail: (msg: u8*) {
    console_write("as: ".data)
    console_writeln(msg)
    err_flag = 1
}

; 1 if c is a token separator (space, tab, comma).
is_sep: (c: u8) -> i64 {
    if c == ' ' {
        return 1
    }
    if c == '\t' {
        return 1
    }
    if c == ',' {
        return 1
    }
    return 0
}

; Truncate the line at the first comment character (';' or '#').
strip_comment: (line: u8*) {
    i: u64 = 0
    while @(line + i) != 0 {
        c: u8 = @(line + i)
        if c == ';' {
            t: u8* = line + i
            @t = 0 as u8
            return
        }
        if c == '#' {
            t: u8* = line + i
            @t = 0 as u8
            return
        }
        i = i + 1
    }
}

; Split `line` into the global token table, returning the token count.
tokenize: (line: u8*) {
    n: i64 = 0
    i: u64 = 0
    while 1 == 1 {
        while is_sep(@(line + i)) == 1 {
            i = i + 1
        }
        if @(line + i) == 0 {
            break
        }
        if n >= 6 {
            break
        }
        dst: u8* = tok_at(n)
        k: u64 = 0
        while 1 == 1 {
            c: u8 = @(line + i)
            if c == 0 {
                break
            }
            if is_sep(c) == 1 {
                break
            }
            if k < 23 {
                d: u8* = dst + k
                @d = c
                k = k + 1
            }
            i = i + 1
        }
        term: u8* = dst + k
        @term = 0 as u8
        n = n + 1
    }
    ntok = n
}

; 1 if token `p` ends with ':' (a label definition).
ends_colon: (p: u8*) -> i64 {
    l: u64 = cstr_len(p)
    if l == 0 {
        return 0
    }
    if @(p + (l - 1)) == ':' {
        return 1
    }
    return 0
}

; Strip a trailing ':' from a label token in place.
drop_colon: (p: u8*) {
    l: u64 = cstr_len(p)
    if l > 0 {
        t: u8* = p + (l - 1)
        @t = 0 as u8
    }
}

; --- Register and immediate parsing ---

; Parse an unsigned decimal starting at p (used for x<N> register numbers).
parse_uint: (p: u8*) -> i64 {
    v: i64 = 0
    i: u64 = 0
    while @(p + i) != 0 {
        c: u8 = @(p + i)
        if c < '0' {
            return v
        }
        if c > '9' {
            return v
        }
        v = v * 10 + (c as i64 - '0')
        i = i + 1
    }
    return v
}

; Map a register token to its number 0..31, or -1 on error (sets err_flag).
reg_num: (p: u8*) -> i64 {
    if cstr_eq(p, "zero".data) == 1 {
        return 0
    }
    if cstr_eq(p, "ra".data) == 1 {
        return 1
    }
    if cstr_eq(p, "sp".data) == 1 {
        return 2
    }
    if cstr_eq(p, "gp".data) == 1 {
        return 3
    }
    if cstr_eq(p, "tp".data) == 1 {
        return 4
    }
    if cstr_eq(p, "t0".data) == 1 {
        return 5
    }
    if cstr_eq(p, "t1".data) == 1 {
        return 6
    }
    if cstr_eq(p, "t2".data) == 1 {
        return 7
    }
    if cstr_eq(p, "fp".data) == 1 {
        return 8
    }
    if cstr_eq(p, "s0".data) == 1 {
        return 8
    }
    if cstr_eq(p, "s1".data) == 1 {
        return 9
    }
    if cstr_eq(p, "a0".data) == 1 {
        return 10
    }
    if cstr_eq(p, "a1".data) == 1 {
        return 11
    }
    if cstr_eq(p, "a2".data) == 1 {
        return 12
    }
    if cstr_eq(p, "a3".data) == 1 {
        return 13
    }
    if cstr_eq(p, "a4".data) == 1 {
        return 14
    }
    if cstr_eq(p, "a5".data) == 1 {
        return 15
    }
    if cstr_eq(p, "a6".data) == 1 {
        return 16
    }
    if cstr_eq(p, "a7".data) == 1 {
        return 17
    }
    if cstr_eq(p, "s2".data) == 1 {
        return 18
    }
    if cstr_eq(p, "s3".data) == 1 {
        return 19
    }
    if cstr_eq(p, "s4".data) == 1 {
        return 20
    }
    if cstr_eq(p, "s5".data) == 1 {
        return 21
    }
    if cstr_eq(p, "s6".data) == 1 {
        return 22
    }
    if cstr_eq(p, "s7".data) == 1 {
        return 23
    }
    if cstr_eq(p, "s8".data) == 1 {
        return 24
    }
    if cstr_eq(p, "s9".data) == 1 {
        return 25
    }
    if cstr_eq(p, "s10".data) == 1 {
        return 26
    }
    if cstr_eq(p, "s11".data) == 1 {
        return 27
    }
    if cstr_eq(p, "t3".data) == 1 {
        return 28
    }
    if cstr_eq(p, "t4".data) == 1 {
        return 29
    }
    if cstr_eq(p, "t5".data) == 1 {
        return 30
    }
    if cstr_eq(p, "t6".data) == 1 {
        return 31
    }
    ; Raw x<N> form.
    if @p == 'x' {
        n: i64 = parse_uint(p + 1)
        if n >= 0 {
            if n <= 31 {
                return n
            }
        }
    }
    fail("bad register".data)
    return -1
}

; Parse a signed immediate: optional '-', then decimal or 0x hex.
parse_imm: (p: u8*) -> i64 {
    i: u64 = 0
    neg: i64 = 0
    if @(p + i) == '-' {
        neg = 1
        i = i + 1
    }
    v: i64 = 0
    ; Hex form 0x...
    if @(p + i) == '0' {
        if @(p + i + 1) == 'x' {
            i = i + 2
            while @(p + i) != 0 {
                c: u8 = @(p + i)
                d: i64 = -1
                if c >= '0' {
                    if c <= '9' {
                        d = c as i64 - '0'
                    }
                }
                if c >= 'a' {
                    if c <= 'f' {
                        d = c as i64 - 87
                    }
                }
                if c >= 'A' {
                    if c <= 'F' {
                        d = c as i64 - 55
                    }
                }
                if d < 0 {
                    break
                }
                v = v * 16 + d
                i = i + 1
            }
            if neg == 1 {
                return 0 - v
            }
            return v
        }
    }
    ; Decimal.
    while @(p + i) != 0 {
        c: u8 = @(p + i)
        if c < '0' {
            break
        }
        if c > '9' {
            break
        }
        v = v * 10 + (c as i64 - '0')
        i = i + 1
    }
    if neg == 1 {
        return 0 - v
    }
    return v
}

; Last memory operand parsed by parse_mem: `offset(reg)` split into its parts.
mem_imm: i64 = 0
mem_reg: i64 = 0

; Parse a `offset(reg)` operand into mem_imm and mem_reg (e.g. `-8(sp)`).
parse_mem: (p: u8*) {
    mem_imm = parse_imm(p)
    ; Advance to the opening parenthesis.
    i: u64 = 0
    while @(p + i) != 0 {
        if @(p + i) == '(' {
            break
        }
        i = i + 1
    }
    if @(p + i) != '(' {
        fail("bad memory operand".data)
        mem_reg = 0
        return
    }
    i = i + 1
    ; Copy the register name (up to the closing parenthesis) and resolve it.
    rbuf: u8[8]
    rp: u8* = rbuf[0]
    k: u64 = 0
    while @(p + i) != 0 {
        c: u8 = @(p + i)
        if c == ')' {
            break
        }
        if k < 7 {
            d: u8* = rp + k
            @d = c
            k = k + 1
        }
        i = i + 1
    }
    t: u8* = rp + k
    @t = 0 as u8
    mem_reg = reg_num(rp)
}

; --- Label table ---

; Record a label at section-local offset `off` in section `sec` (0 text, 1 data).
; resolve_labels() rewrites data offsets to absolute payload positions after pass 1.
add_label: (name: u8*, off: i64, sec: i64) {
    if lbl_count >= 64 {
        fail("too many labels".data)
        return
    }
    lab: Label* = labels[lbl_count]
    dst: u8* = lab as u8*
    i: u64 = 0
    while 1 == 1 {
        c: u8 = @(name + i)
        if i >= 15 {
            break
        }
        d: u8* = dst + i
        @d = c
        if c == 0 {
            break
        }
        i = i + 1
    }
    t: u8* = dst + i
    @t = 0 as u8
    @lab.addr = off
    @lab.sec = sec
    lbl_count = lbl_count + 1
}

; After pass 1, turn data-section label offsets into absolute payload positions
; (data follows the text and its NOP pad). Text labels are already absolute.
resolve_labels: () {
    i: i64 = 0
    while i < lbl_count {
        lab: Label* = labels[i]
        if @lab.sec == 1 {
            @lab.addr = text_total + PAD + @lab.addr
        }
        i = i + 1
    }
}

; Resolve a label name to its byte address, or -1 if undefined (sets err_flag).
find_label: (name: u8*) -> i64 {
    i: i64 = 0
    while i < lbl_count {
        lab: Label* = labels[i]
        cand: u8* = lab as u8*
        if cstr_eq(cand, name) == 1 {
            return @lab.addr
        }
        i = i + 1
    }
    fail("undefined label".data)
    return -1
}

; 1 if `name` is a locally-defined label (no error on miss, unlike find_label).
label_defined: (name: u8*) -> i64 {
    i: i64 = 0
    while i < lbl_count {
        lab: Label* = labels[i]
        cand: u8* = lab as u8*
        if cstr_eq(cand, name) == 1 {
            return 1
        }
        i = i + 1
    }
    return 0
}

; Record a `.globl name` export (deduplicated).
add_globl: (name: u8*) {
    if is_globl(name) == 1 {
        return
    }
    if glbl_count >= 32 {
        return
    }
    dst: u8* = glbl_names[0] + (glbl_count as u64) * 16
    i: u64 = 0
    while i < 15 {
        c: u8 = @(name + i)
        e: u8* = dst + i
        @e = c
        if c == 0 {
            glbl_count = glbl_count + 1
            return
        }
        i = i + 1
    }
    z: u8* = dst + 15
    @z = 0 as u8
    glbl_count = glbl_count + 1
}

; 1 if `name` was exported via `.globl`.
is_globl: (name: u8*) -> i64 {
    i: i64 = 0
    while i < glbl_count {
        cand: u8* = glbl_names[0] + (i as u64) * 16
        if cstr_eq(cand, name) == 1 {
            return 1
        }
        i = i + 1
    }
    return 0
}

; Record a relocation at .text byte offset `off` against `name` (kind as above).
add_reloc: (name: u8*, off: i64, kind: i64) {
    if nreloc >= 256 {
        fail("too many relocations".data)
        return
    }
    r: Reloc* = relocs[nreloc]
    dst: u8* = r as u8*
    i: u64 = 0
    while i < 15 {
        c: u8 = @(name + i)
        e: u8* = dst + i
        @e = c
        if c == 0 {
            break
        }
        i = i + 1
    }
    t: u8* = dst + i
    @t = 0 as u8
    @r.off = off
    @r.kind = kind
    nreloc = nreloc + 1
}

; --- Encoding ---

push_byte: (b: u8) {
    if code_len < 8192 {
        @code[code_len] = b
        code_len = code_len + 1
    }
}

emit_word: (w: u32) {
    push_byte(w as u8)
    push_byte((w >> 8) as u8)
    push_byte((w >> 16) as u8)
    push_byte((w >> 24) as u8)
}

; Write an `n`-byte little-endian value into the output image at byte offset `off`.
; Used to lay down the ELF header and program header fields.
wr_le: (off: u64, val: u64, n: u64) {
    k: u64 = 0
    while k < n {
        d: u8* = out[0] + off + k
        @d = (val >> (k * 8)) as u8
        k = k + 1
    }
}

enc_r: (rd: i64, rs1: i64, rs2: i64, funct3: i64, funct7: i64) -> u32 {
    return ((funct7 as u32) << 25) | ((rs2 as u32) << 20) | ((rs1 as u32) << 15)
         | ((funct3 as u32) << 12) | ((rd as u32) << 7) | (0x33 as u32)
}

enc_i: (rd: i64, rs1: i64, imm: i64, funct3: i64, opcode: i64) -> u32 {
    return (((imm as u32) & 0xFFF) << 20) | ((rs1 as u32) << 15)
         | ((funct3 as u32) << 12) | ((rd as u32) << 7) | (opcode as u32)
}

enc_b: (rs1: i64, rs2: i64, imm: i64, funct3: i64) -> u32 {
    u: u32 = imm as u32
    i12: u32 = (u >> 12) & 1
    i11: u32 = (u >> 11) & 1
    i10_5: u32 = (u >> 5) & 0x3F
    i4_1: u32 = (u >> 1) & 0xF
    return (i12 << 31) | (i10_5 << 25) | ((rs2 as u32) << 20) | ((rs1 as u32) << 15)
         | ((funct3 as u32) << 12) | (i4_1 << 8) | (i11 << 7) | (0x63 as u32)
}

enc_j: (rd: i64, imm: i64) -> u32 {
    u: u32 = imm as u32
    i20: u32 = (u >> 20) & 1
    i10_1: u32 = (u >> 1) & 0x3FF
    i11: u32 = (u >> 11) & 1
    i19_12: u32 = (u >> 12) & 0xFF
    return (i20 << 31) | (i10_1 << 21) | (i11 << 20) | (i19_12 << 12)
         | ((rd as u32) << 7) | (0x6F as u32)
}

enc_s: (rs1: i64, rs2: i64, imm: i64, funct3: i64) -> u32 {
    u: u32 = imm as u32
    i11_5: u32 = (u >> 5) & 0x7F
    i4_0: u32 = u & 0x1F
    return (i11_5 << 25) | ((rs2 as u32) << 20) | ((rs1 as u32) << 15)
         | ((funct3 as u32) << 12) | (i4_0 << 7) | (0x23 as u32)
}

; U-type (lui/auipc): the operand is the 20-bit value placed in bits 31:12.
enc_u: (rd: i64, imm: i64, opcode: i64) -> u32 {
    return (((imm as u32) & 0xFFFFF) << 12) | ((rd as u32) << 7) | (opcode as u32)
}

; Number of bytes an `li rd, imm` expands to (addi, or lui+addi for wide).
li_size: (imm: i64) -> i64 {
    if imm >= -2048 {
        if imm <= 2047 {
            return 4
        }
    }
    return 8
}

; Emit `li rd, imm`. Single addi for 12-bit signed; lui+addi for 0..0x7FFFFFFF.
emit_li: (rd: i64, imm: i64) {
    if imm >= -2048 {
        if imm <= 2047 {
            emit_word(enc_i(rd, 0, imm, 0, 0x13))
            return
        }
    }
    if imm < 0 {
        fail("li: negative immediate too wide".data)
        return
    }
    ; lui carries a 20-bit field, so the split must fit hi in [0, 0xFFFFF].
    hi: i64 = (imm + 2048) / 4096
    if hi > 1048575 {
        fail("li: immediate too wide".data)
        return
    }
    lo: i64 = imm - hi * 4096
    emit_word(((hi as u32) & 0xFFFFF) << 12 | ((rd as u32) << 7) | (0x37 as u32))
    emit_word(enc_i(rd, rd, lo, 0, 0x13))
}

; --- Data section emission ---

push_data_byte: (b: u8) {
    if data_len < 8192 {
        @data[data_len] = b
        data_len = data_len + 1
    }
}

emit_data_word: (w: u32) {
    push_data_byte(w as u8)
    push_data_byte((w >> 8) as u8)
    push_data_byte((w >> 16) as u8)
    push_data_byte((w >> 24) as u8)
}

; PC-relative split for auipc+addi / auipc+jalr pairs (la, call). The hi field is
; left signed; enc_u/enc_i mask it. Both halves reference the auipc's pc.
pcrel_hi: i64 = 0
pcrel_lo: i64 = 0
split_pcrel: (delta: i64) {
    lo: i64 = delta & 0xFFF
    if lo >= 2048 {
        lo = lo - 4096
    }
    pcrel_lo = lo
    pcrel_hi = (delta - lo) >> 12
}

; Emit/size a quoted string from a .ascii/.asciz line (`zt` adds a NUL). Strings
; cannot contain ';' or '#' (the line is comment-stripped first). Returns length.
data_string: (pass: i64, line_p: u8*, zt: i64) -> i64 {
    i: u64 = 0
    while @(line_p + i) != 0 {
        if @(line_p + i) == '"' {
            break
        }
        i = i + 1
    }
    if @(line_p + i) != '"' {
        fail("string: missing quote".data)
        return 0
    }
    i = i + 1
    n: i64 = 0
    while @(line_p + i) != 0 {
        c: u8 = @(line_p + i)
        if c == '"' {
            break
        }
        if c == '\\' {
            i = i + 1
            e: u8 = @(line_p + i)
            c = e
            if e == 'n' {
                c = '\n' as u8
            }
            if e == 't' {
                c = '\t' as u8
            }
            if e == 'r' {
                c = '\r' as u8
            }
            if e == '0' {
                c = 0 as u8
            }
            if e == '\\' {
                c = '\\' as u8
            }
            if e == '"' {
                c = '"' as u8
            }
        }
        if pass == 2 {
            push_data_byte(c)
        }
        n = n + 1
        i = i + 1
    }
    if zt == 1 {
        if pass == 2 {
            push_data_byte(0 as u8)
        }
        n = n + 1
    }
    return n
}

; Handle a directive line. Section directives switch cur_sec and return 0; data
; directives emit (pass 2) and return the byte count they add to the data section.
handle_directive: (pass: i64, base: i64, line_p: u8*) -> i64 {
    d: u8* = tok_at(base)
    if cstr_eq(d, ".text".data) == 1 {
        cur_sec = 0
        return 0
    }
    if cstr_eq(d, ".data".data) == 1 {
        cur_sec = 1
        return 0
    }
    if cstr_eq(d, ".rodata".data) == 1 {
        cur_sec = 1
        return 0
    }
    if cstr_eq(d, ".bss".data) == 1 {
        cur_sec = 1
        return 0
    }
    if cstr_eq(d, ".section".data) == 1 {
        a: u8* = tok_at(base + 1)
        if cstr_eq(a, ".text".data) == 1 {
            cur_sec = 0
        } else {
            cur_sec = 1
        }
        return 0
    }
    if cstr_eq(d, ".globl".data) == 1 {
        if pass == 1 {
            add_globl(tok_at(base + 1))
        }
        return 0
    }
    if cstr_eq(d, ".byte".data) == 1 {
        if pass == 2 {
            push_data_byte(parse_imm(tok_at(base + 1)) as u8)
        }
        return 1
    }
    if cstr_eq(d, ".word".data) == 1 {
        if pass == 2 {
            emit_data_word(parse_imm(tok_at(base + 1)) as u32)
        }
        return 4
    }
    if cstr_eq(d, ".zero".data) == 1 {
        n: i64 = parse_imm(tok_at(base + 1))
        if pass == 2 {
            k: i64 = 0
            while k < n {
                push_data_byte(0 as u8)
                k = k + 1
            }
        }
        return n
    }
    if cstr_eq(d, ".asciz".data) == 1 {
        return data_string(pass, line_p, 1)
    }
    if cstr_eq(d, ".ascii".data) == 1 {
        return data_string(pass, line_p, 0)
    }
    fail("unknown directive".data)
    return 0
}

; Assemble one tokenized instruction at token `base`; pass 1 sizes only, pass 2
; encodes. `pc` is the current byte address (for branch offsets). Returns the size.
encode_instr: (pass: i64, base: i64, pc: i64) -> i64 {
    m: u8* = tok_at(base)
    o0: u8* = tok_at(base + 1)
    o1: u8* = tok_at(base + 2)
    o2: u8* = tok_at(base + 3)

    if cstr_eq(m, "ecall".data) == 1 {
        if pass == 2 {
            emit_word(0x73 as u32)
        }
        return 4
    }
    if cstr_eq(m, "ret".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(0, 1, 0, 0, 0x67))
        }
        return 4
    }
    if cstr_eq(m, "li".data) == 1 {
        imm: i64 = parse_imm(o1)
        if pass == 2 {
            emit_li(reg_num(o0), imm)
        }
        return li_size(imm)
    }
    if cstr_eq(m, "mv".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), 0, 0, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "addi".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 0, 0x13))
        }
        return 4
    }
    ; addiw is the 32-bit word add-immediate (opcode 0x1B); the host backend
    ; normalizes every i32 result through it, so the HLL-0 subset needs it.
    if cstr_eq(m, "addiw".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 0, 0x1B))
        }
        return 4
    }
    if cstr_eq(m, "add".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 0, 0))
        }
        return 4
    }
    if cstr_eq(m, "sub".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 0, 0x20))
        }
        return 4
    }
    if cstr_eq(m, "and".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 7, 0))
        }
        return 4
    }
    if cstr_eq(m, "or".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 6, 0))
        }
        return 4
    }
    if cstr_eq(m, "xor".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 4, 0))
        }
        return 4
    }
    ; --- M-extension: 64-bit multiply / divide (opcode 0x33, funct7 = 0x01) ---
    ; Needed for HLL `* / %`; mirrors asm-to-binary rv64m encodings.
    if cstr_eq(m, "mul".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 0, 1))
        }
        return 4
    }
    if cstr_eq(m, "div".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 4, 1))
        }
        return 4
    }
    if cstr_eq(m, "divu".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 5, 1))
        }
        return 4
    }
    if cstr_eq(m, "rem".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 6, 1))
        }
        return 4
    }
    if cstr_eq(m, "remu".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 7, 1))
        }
        return 4
    }
    if cstr_eq(m, "j".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o0)
            emit_word(enc_j(0, target - pc))
        }
        return 4
    }
    if cstr_eq(m, "beq".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o2)
            emit_word(enc_b(reg_num(o0), reg_num(o1), target - pc, 0))
        }
        return 4
    }
    if cstr_eq(m, "bne".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o2)
            emit_word(enc_b(reg_num(o0), reg_num(o1), target - pc, 1))
        }
        return 4
    }
    if cstr_eq(m, "blt".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o2)
            emit_word(enc_b(reg_num(o0), reg_num(o1), target - pc, 4))
        }
        return 4
    }
    if cstr_eq(m, "bge".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o2)
            emit_word(enc_b(reg_num(o0), reg_num(o1), target - pc, 5))
        }
        return 4
    }
    if cstr_eq(m, "bltu".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o2)
            emit_word(enc_b(reg_num(o0), reg_num(o1), target - pc, 6))
        }
        return 4
    }
    if cstr_eq(m, "bgeu".data) == 1 {
        if pass == 2 {
            target: i64 = find_label(o2)
            emit_word(enc_b(reg_num(o0), reg_num(o1), target - pc, 7))
        }
        return 4
    }

    ; --- Jumps and PC-relative address materialization ---
    if cstr_eq(m, "jal".data) == 1 {
        if pass == 2 {
            if obj_mode == 1 {
                if label_defined(o1) == 0 {
                    add_reloc(o1, pc, 1)
                    emit_word(enc_j(reg_num(o0), 0))
                    return 4
                }
            }
            target: i64 = find_label(o1)
            emit_word(enc_j(reg_num(o0), target - pc))
        }
        return 4
    }
    if cstr_eq(m, "jalr".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 0, 0x67))
        }
        return 4
    }
    ; call/la expand to auipc + jalr/addi against the current pc (8 bytes).
    if cstr_eq(m, "call".data) == 1 {
        if pass == 2 {
            if obj_mode == 1 {
                if label_defined(o0) == 0 {
                    add_reloc(o0, pc, 0)
                    emit_word(enc_u(1, 0, 0x17))
                    emit_word(enc_i(1, 1, 0, 0, 0x67))
                    return 8
                }
            }
            target: i64 = find_label(o0)
            split_pcrel(target - pc)
            emit_word(enc_u(1, pcrel_hi, 0x17))
            emit_word(enc_i(1, 1, pcrel_lo, 0, 0x67))
        }
        return 8
    }
    ; la always relocates in object mode (section merging shifts cross-section
    ; distances); the local pcrel is still prefilled and overwritten by ld.
    if cstr_eq(m, "la".data) == 1 {
        if pass == 2 {
            rd: i64 = reg_num(o0)
            if obj_mode == 1 {
                add_reloc(o1, pc, 2)
                hi: i64 = 0
                lo: i64 = 0
                if label_defined(o1) == 1 {
                    split_pcrel(find_label(o1) - pc)
                    hi = pcrel_hi
                    lo = pcrel_lo
                }
                emit_word(enc_u(rd, hi, 0x17))
                emit_word(enc_i(rd, rd, lo, 0, 0x13))
                return 8
            }
            target: i64 = find_label(o1)
            split_pcrel(target - pc)
            emit_word(enc_u(rd, pcrel_hi, 0x17))
            emit_word(enc_i(rd, rd, pcrel_lo, 0, 0x13))
        }
        return 8
    }

    ; --- Register-register (R-type) ---
    if cstr_eq(m, "sll".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 1, 0))
        }
        return 4
    }
    if cstr_eq(m, "srl".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 5, 0))
        }
        return 4
    }
    if cstr_eq(m, "sra".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 5, 0x20))
        }
        return 4
    }
    if cstr_eq(m, "slt".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 2, 0))
        }
        return 4
    }
    if cstr_eq(m, "sltu".data) == 1 {
        if pass == 2 {
            emit_word(enc_r(reg_num(o0), reg_num(o1), reg_num(o2), 3, 0))
        }
        return 4
    }

    ; --- Register-immediate (I-type, opcode 0x13) ---
    if cstr_eq(m, "andi".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 7, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "ori".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 6, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "xori".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 4, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "slti".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 2, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "sltiu".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 3, 0x13))
        }
        return 4
    }

    ; --- Shift-immediate (shamt in the low bits; srai sets funct7=0x20) ---
    if cstr_eq(m, "slli".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 1, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "srli".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2), 5, 0x13))
        }
        return 4
    }
    if cstr_eq(m, "srai".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(reg_num(o0), reg_num(o1), parse_imm(o2) | 0x400, 5, 0x13))
        }
        return 4
    }

    ; --- Loads (rd, offset(rs1); opcode 0x03) ---
    if cstr_eq(m, "ld".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 3, 0x03))
        }
        return 4
    }
    if cstr_eq(m, "lw".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 2, 0x03))
        }
        return 4
    }
    if cstr_eq(m, "lwu".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 6, 0x03))
        }
        return 4
    }
    if cstr_eq(m, "lh".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 1, 0x03))
        }
        return 4
    }
    if cstr_eq(m, "lhu".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 5, 0x03))
        }
        return 4
    }
    if cstr_eq(m, "lb".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 0, 0x03))
        }
        return 4
    }
    if cstr_eq(m, "lbu".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_i(reg_num(o0), mem_reg, mem_imm, 4, 0x03))
        }
        return 4
    }

    ; --- Stores (rs2, offset(rs1); opcode 0x23) ---
    if cstr_eq(m, "sd".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_s(mem_reg, reg_num(o0), mem_imm, 3))
        }
        return 4
    }
    if cstr_eq(m, "sw".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_s(mem_reg, reg_num(o0), mem_imm, 2))
        }
        return 4
    }
    if cstr_eq(m, "sh".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_s(mem_reg, reg_num(o0), mem_imm, 1))
        }
        return 4
    }
    if cstr_eq(m, "sb".data) == 1 {
        if pass == 2 {
            parse_mem(o1)
            emit_word(enc_s(mem_reg, reg_num(o0), mem_imm, 0))
        }
        return 4
    }

    ; --- Upper-immediate (rd, imm20) ---
    if cstr_eq(m, "lui".data) == 1 {
        if pass == 2 {
            emit_word(enc_u(reg_num(o0), parse_imm(o1), 0x37))
        }
        return 4
    }
    if cstr_eq(m, "auipc".data) == 1 {
        if pass == 2 {
            emit_word(enc_u(reg_num(o0), parse_imm(o1), 0x17))
        }
        return 4
    }

    if cstr_eq(m, "nop".data) == 1 {
        if pass == 2 {
            emit_word(enc_i(0, 0, 0, 0, 0x13))
        }
        return 4
    }

    fail("unknown instruction".data)
    return 0
}

; One assembly pass over the source. Pass 1 records label addresses; pass 2
; encodes instructions into `code`.
assemble: (pass: i64) {
    i: u64 = 0
    tpc: i64 = 0
    dpc: i64 = 0
    cur_sec = 0
    line: u8[256]
    line_p: u8* = line[0]
    while i < src_len {
        ; Extract one line (without the newline) into line_p.
        j: u64 = 0
        while i < src_len {
            c: u8 = @src[i]
            i = i + 1
            if c == '\n' {
                break
            }
            if c != '\r' {
                if j < 255 {
                    d: u8* = line_p + j
                    @d = c
                    j = j + 1
                }
            }
        }
        term: u8* = line_p + j
        @term = 0 as u8

        strip_comment(line_p)
        tokenize(line_p)
        if ntok == 0 {
            ; blank or comment-only line
        } else {
            base: i64 = 0
            first: u8* = tok_at(0)
            if ends_colon(first) == 1 {
                drop_colon(first)
                if pass == 1 {
                    if cur_sec == 0 {
                        add_label(first, tpc, 0)
                    } else {
                        add_label(first, dpc, 1)
                    }
                }
                base = 1
            }
            if base < ntok {
                d0: u8* = tok_at(base)
                if @d0 == '.' {
                    ; Directive (leading '.'); may switch section or emit data.
                    sz: i64 = handle_directive(pass, base, line_p)
                    if cur_sec == 1 {
                        dpc = dpc + sz
                    }
                } else {
                    size: i64 = encode_instr(pass, base, tpc)
                    tpc = tpc + size
                }
            }
        }
    }
    if pass == 1 {
        text_total = tpc
    }
}

; Split the argument "src out" at the first space into two path buffers.
split_arg: (arg: u8*, src_path: u8*, out_path: u8*) -> i64 {
    i: u64 = 0
    while @(arg + i) != 0 {
        if @(arg + i) == ' ' {
            break
        }
        d: u8* = src_path + i
        @d = @(arg + i)
        i = i + 1
    }
    st: u8* = src_path + i
    @st = 0 as u8
    if @(arg + i) == 0 {
        return 0
    }
    ; Skip the separating space(s).
    while @(arg + i) == ' ' {
        i = i + 1
    }
    if @(arg + i) == 0 {
        return 0
    }
    k: u64 = 0
    while @(arg + i) != 0 {
        d: u8* = out_path + k
        @d = @(arg + i)
        i = i + 1
        k = k + 1
    }
    ot: u8* = out_path + k
    @ot = 0 as u8
    return 1
}

; --- ET_REL object emission ---

; 1 if path ends in the two-character suffix ".o".
ends_dot_o: (path: u8*) -> i64 {
    l: u64 = cstr_len(path)
    if l < 2 {
        return 0
    }
    if @(path + (l - 2)) == '.' {
        if @(path + (l - 1)) == 'o' {
            return 1
        }
    }
    return 0
}

main: () -> i32 {
    ; Allocate the assembler's working buffers on the heap (formerly fixed .bss).
    src = new(u8, 8192)
    code = new(u8, 8192)
    data = new(u8, 8192)
    out = new(u8, 32768)
    labels = new(Label, 64)
    tokbuf = new(u8, 144)
    glbl_names = new(u8, 512)
    relocs = new(Reloc, 256)

    arg: u8* = ARG_BASE as u8*
    src_path: u8[128]
    out_path: u8[128]
    src_pp: u8* = src_path[0]
    out_pp: u8* = out_path[0]
    if split_arg(arg, src_pp, out_pp) == 0 {
        console_writeln("as: usage: as <src> <out>".data)
        return 1
    }

    fd: i64 = sc_open(src_pp, 0)
    if fd < 0 {
        console_write("as: cannot open ".data)
        console_writeln(src_pp)
        return 1
    }
    n: i64 = sc_read(fd, src[0], 0, 8191)
    sc_close(fd)
    if n <= 0 {
        console_writeln("as: empty source".data)
        return 1
    }
    src_len = n as u64
    @src[src_len] = 0 as u8

    obj_mode = ends_dot_o(out_pp)
    lbl_count = 0
    code_len = 0
    data_len = 0
    err_flag = 0
    glbl_count = 0
    nreloc = 0
    assemble(1)
    ; In object mode keep section-relative label addresses (the linker relocates);
    ; the exe path remaps data labels into the flat payload.
    if obj_mode == 0 {
        resolve_labels()
    }
    code_len = 0
    data_len = 0
    assemble(2)
    if err_flag != 0 {
        return 1
    }

    ; Object output: emit a relocatable ELF for ld.hll, then write and return.
    if obj_mode == 1 {
        ototal: u64 = write_object()
        oofd: i64 = sc_open(out_pp, 2)
        if oofd < 0 {
            console_write("as: cannot create ".data)
            console_writeln(out_pp)
            return 1
        }
        sc_write(oofd, out[0], ototal)
        sc_ftruncate(oofd, ototal)
        sc_close(oofd)
        console_write("as: wrote ".data)
        console_writeln(out_pp)
        return 0
    }

    ; Append NOP padding so a speculative fetch past the final ecall stays valid
    ; (a zero word would trap to M-mode and halt). OS spec 10.3; PAD matches the label gap.
    pad: u64 = 0
    while pad < 8 {
        emit_word(0x13 as u32)
        pad = pad + 1
    }
    ; The data section follows the text and its pad in the flat payload.
    di: u64 = 0
    while di < data_len {
        push_byte(@data[di])
        di = di + 1
    }

    ; Minimal static ELF64: 64-byte header + one 56-byte PT_LOAD in the first page,
    ; payload at HDR. sys_exec reads e_entry + the PT_LOAD and maps it at p_vaddr.
    base: u64 = USER_CODE_BASE as u64
    ; e_ident: 0x7F 'E' 'L' 'F', ELFCLASS64, ELFDATA2LSB, EV_CURRENT; rest zero.
    @out[0] = 0x7F as u8
    @out[1] = 69 as u8   ; 'E'
    @out[2] = 76 as u8   ; 'L'
    @out[3] = 70 as u8   ; 'F'
    @out[4] = 2 as u8    ; ELFCLASS64
    @out[5] = 1 as u8    ; ELFDATA2LSB (little-endian)
    @out[6] = 1 as u8    ; EV_CURRENT
    wr_le(16, 2, 2)              ; e_type = ET_EXEC
    wr_le(18, 243, 2)            ; e_machine = EM_RISCV
    wr_le(20, 1, 4)              ; e_version = EV_CURRENT
    wr_le(24, base, 8)           ; e_entry (text starts at the payload base)
    wr_le(32, 64, 8)            ; e_phoff (program header follows the ELF header)
    ; e_shoff (40) stays 0: no section headers.
    wr_le(48, 5, 4)             ; e_flags (RVC | double-float ABI; informational)
    wr_le(52, 64, 2)            ; e_ehsize
    wr_le(54, 56, 2)            ; e_phentsize
    wr_le(56, 1, 2)            ; e_phnum (one PT_LOAD)
    ; e_shentsize/e_shnum/e_shstrndx (58/60/62) stay 0.

    ; One PT_LOAD covering the whole payload, mapped R|W|X at the load base.
    wr_le(64, 1, 4)            ; p_type = PT_LOAD
    wr_le(68, 7, 4)            ; p_flags = R|W|X
    wr_le(72, HDR as u64, 8)   ; p_offset (payload at the page boundary)
    wr_le(80, base, 8)         ; p_vaddr
    wr_le(88, base, 8)         ; p_paddr
    wr_le(96, code_len, 8)     ; p_filesz
    wr_le(104, code_len, 8)    ; p_memsz (no separate BSS; .zero is in the payload)
    wr_le(112, 4096, 8)        ; p_align

    ; out[120..HDR] stay zero; the payload follows at the page boundary.
    i: u64 = 0
    while i < code_len {
        d: u8* = out[0] + (HDR as u64) + i
        @d = @code[i]
        i = i + 1
    }
    total: u64 = (HDR as u64) + code_len

    ofd: i64 = sc_open(out_pp, 2)
    if ofd < 0 {
        console_write("as: cannot create ".data)
        console_writeln(out_pp)
        return 1
    }
    sc_write(ofd, out[0], total)
    sc_ftruncate(ofd, total)
    sc_close(ofd)

    console_write("as: wrote ".data)
    console_writeln(out_pp)
    return 0
}
