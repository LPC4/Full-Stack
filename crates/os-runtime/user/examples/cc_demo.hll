; Pure HLL-0 demo for `cc` (prints "HLL0\nY", exits 36); leaves putc to cc's
; built-in intrinsic, so it is for `cc`, not the host toolchain. See OS spec 10.4.

sum_to: (n: i32) -> i32 {
    total: i32 = 0
    i: i32 = 1
    while i <= n {
        total = total + i
        i = i + 1
    }
    return total
}

main: () -> i32 {
    putc('H')
    putc('L')
    putc('L')
    putc('0')
    putc('\n')
    n: i32 = sum_to(8)
    if n > 30 {
        putc('Y')
    }
    return n
}
