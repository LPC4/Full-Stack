# Sv39 Virtual Memory Test Program
# This test sets up page tables and switches to S-mode to test address translation

.section .text
.globl _start

_start:
    # Initialize stack pointer
    li sp, 0x80000000
    
    # Setup page tables for identity mapping of first few pages
    # We'll map virtual address 0x0-0x200000 to physical 0x0-0x200000
    
    # Level 2 page table at physical address 0x1000
    # Level 1 page table at physical address 0x2000  
    # Level 0 page table at physical address 0x3000
    
    # Set up level 2 PTE[0] to point to level 1 table
    # PTE format: [PPN][flags]
    # For non-leaf: V=1, R=0, W=0, X=0, PPN points to next level
    li t0, 0x1000          # Level 2 table address
    li t1, 0x2000          # Level 1 table physical address
    srli t1, t1, 12        # Convert to PPN
    slli t1, t1, 10        # Shift to PPN position in PTE
    ori t1, t1, 0x1        # Set V bit (valid)
    sd t1, 0(t0)           # Store PTE[0] in level 2 table
    
    # Set up level 1 PTE[0] to point to level 0 table
    li t0, 0x2000          # Level 1 table address
    li t1, 0x3000          # Level 0 table physical address
    srli t1, t1, 12        # Convert to PPN
    slli t1, t1, 10        # Shift to PPN position in PTE
    ori t1, t1, 0x1        # Set V bit (valid)
    sd t1, 0(t0)           # Store PTE[0] in level 1 table
    
    # Set up level 0 PTE[0] as leaf mapping to physical page 0
    # Leaf PTE: V=1, R=1, W=1, X=1, A=1, D=1 (read/write/execute)
    li t0, 0x3000          # Level 0 table address
    li t1, 0x0             # Physical page 0
    srli t1, t1, 12        # Convert to PPN
    slli t1, t1, 10        # Shift to PPN position in PTE
    ori t1, t1, 0xEF       # Set V|R|W|X|U|A|D bits (0b1110_1111)
    sd t1, 0(t0)           # Store PTE[0] in level 0 table
    
    # Map another page at virtual 0x1000 -> physical 0x1000
    li t1, 0x1             # Physical page 1 (0x1000)
    srli t1, t1, 0         # Already PPN
    slli t1, t1, 10        # Shift to PPN position
    ori t1, t1, 0xEF       # Set permission bits
    sd t1, 8(t0)           # Store PTE[1] in level 0 table
    
    # Load SATP with Sv39 mode and page table base
    # SATP format: [MODE(4)][ASID(16)][PPN(44)]
    # Mode 8 = Sv39, PPN = 0x1000 >> 12 = 1
    li t0, 0x1             # PPN of level 2 table (0x1000 >> 12)
    li t1, 8               # Sv39 mode
    slli t1, t1, 60        # Shift mode to bits [63:60]
    or t0, t0, t1          # Combine mode and PPN
    csrw satp, t0          # Write to SATP
    
    # Switch to S-mode using MRET
    # First, set MPP to S-mode (1)
    li t0, 0x1000          # MPP = 1 (S-mode) in bits [12:11]
    csrs mstatus, t0       # Set MPP
    
    # Set MEPC to continue execution after MRET
    la t0, s_mode_code
    csrw mepc, t0
    
    # Execute MRET to switch to S-mode
    mret

s_mode_code:
    # Now in S-mode with paging enabled
    # Try to access memory through translated addresses
    
    # Test: load from virtual address 0x0 (should map to physical 0x0)
    li t0, 0x0
    ld t1, 0(t0)           # This should work if translation is correct
    
    # Test: store to virtual address 0x1000
    li t0, 0x1000
    li t1, 0xDEADBEEF
    sd t1, 0(t0)
    
    # If we get here, basic paging works!
    # Exit successfully
    li a7, 93              # exit syscall
    li a0, 0               # exit code 0
    ecall
