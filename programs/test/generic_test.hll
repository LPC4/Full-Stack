type Box<T> {
    val: T
    ptr: T*
}

main: () -> i32 {
    ; Test generic type specialization with i32
    box1: Box<i32>* = new(Box<i32>)
    @box1.val = 42
    
    ; Test generic type specialization with i64
    box2: Box<i64>* = new(Box<i64>)
    @box2.val = 100
    
    return @box1.val + 58
}
