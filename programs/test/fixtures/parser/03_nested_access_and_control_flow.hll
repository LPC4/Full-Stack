; Test: Complex Nested Access
type Container {
    items: [5]i32*
}

stress_test: (c: Container*) -> i32 {
    ; Difficulty: Parsing @ combined with array indexing and field access
    ; This should read: dereference ( (index 0 of (field items of (dereference c))) )
    val: i32 = @@c.items[0]

    ; Test: Operator Precedence
    ; Logical 'and' usually binds tighter than 'or'
    check: bool = true or false and not true

    ; Test: Empty blocks and semicolons at end of line
    while check {
        if val > 100 {
            break
        }
        val = val + 1 ;
    }

    return val
}
