; Function returning two values via inline struct
divide: (a: i32, b: i32) -> { result: i32, success: bool } {
    if b == 0 {
        return { result: i32 = 0, success: bool = false }
    }
    return { result: i32 = a / b, success: bool = true }
}

start: () {
    ; Parsing challenge: Handling brace-based typed destructuring
    { result: i32, success: bool } = divide(10, 2)

    if success {
        print(result)
    }
}
