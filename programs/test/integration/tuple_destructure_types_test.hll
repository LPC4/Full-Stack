; Test new tuple destructuring syntax with optional type annotations

divide: (a: i32, b: i32) -> (i32, i32) {
    return {a / b, a % b}
}

test_no_types: () -> i32 {
    ; Destructuring without type annotations
    (q, r) = divide(10, 3)
    return q
}

test_with_types: () -> i32 {
    ; Destructuring with type annotations
    (quotient: i32, remainder: i32) = divide(20, 7)
    return quotient
}

test_mixed_types: () -> i32 {
    ; Mixed: some with types, some without
    (x, y: i32) = divide(15, 4)
    return x + y
}

main: () -> i32 {
    result1: i32 = test_no_types()
    result2: i32 = test_with_types()
    result3: i32 = test_mixed_types()
    
    return result1 + result2 + result3
}
