type Point = {f32, f32}

define f32 @calc_offset(Point* $p, f32 $shift) {
@entry:
	; bind parameter: p
	$p_ptr = stack_alloc Point*
	store Point* $p -> $p_ptr
	; bind parameter: shift
	$shift_ptr = stack_alloc f32
	store f32 $shift -> $shift_ptr
	; assignment
	$0 = load Point* $p_ptr
	$1 = load f32 $0 + 0
	$2 = load f32 $shift_ptr
	$3 = math add f32 $1, $2
	$4 = load Point* $p_ptr
	$5 = offset f32 $4, 0
	store f32 $3 -> $5
	; assignment
	$6 = load Point* $p_ptr
	$7 = load f32 $6 + 8
	$8 = load f32 $shift_ptr
	$9 = math add f32 $7, $8
	$10 = load Point* $p_ptr
	$11 = offset f32 $10, 8
	store f32 $9 -> $11
	$12 = load Point* $p_ptr
	$13 = load f32 $12 + 0
	$14 = load Point* $p_ptr
	$15 = load f32 $14 + 8
	$16 = math mul f32 $13, $15
	ret $16
}