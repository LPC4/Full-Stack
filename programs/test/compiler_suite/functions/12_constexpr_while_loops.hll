; Test compile-time evaluation with while loops

; Calculate sum using while loop
sum_to_n: (n: i32) -> i32 {
    result: i32 = 0
    i: i32 = 1
    
    while i <= n {
        result = result + i
        i = i + 1
    }
    
    return result
}

; Calculate factorial using while loop
factorial_while: (n: i32) -> i32 {
    result: i32 = 1
    i: i32 = 2
    
    while i <= n {
        result = result * i
        i = i + 1
    }
    
    return result
}

; Compile-time constants using while loops
const SUM_10 = sum_to_n(10)
const FACT_7 = factorial_while(7)

main: () {
    print(SUM_10)   ; Should be 55
    print(FACT_7)   ; Should be 5040
}
