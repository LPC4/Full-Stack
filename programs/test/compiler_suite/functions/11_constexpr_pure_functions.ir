define i32 factorial(i32 $n) {
entry:
	; bind parameter: n
	$n_ptr = stack_alloc i32
	write i32 $n @ $n_ptr
	; if condition
	$0 = read i32 @ $n_ptr
	$1 = cmp sle i32 $0, 1
	branch $1 ? label_0 : label_2
label_0:
	ret 1
label_2:
	$2 = read i32 @ $n_ptr
	$3 = read i32 @ $n_ptr
	$4 = math sub i32 $3, 1
	$5 = call factorial($4)
	$6 = math mul i32 $2, $5
	ret $6
}

define i32 fibonacci(i32 $n) {
entry:
	; bind parameter: n
	$n_ptr = stack_alloc i32
	write i32 $n @ $n_ptr
	; if condition
	$0 = read i32 @ $n_ptr
	$1 = cmp sle i32 $0, 0
	branch $1 ? label_3 : label_5
label_3:
	ret 0
label_5:
	; if condition
	$2 = read i32 @ $n_ptr
	$3 = cmp eq i32 $2, 1
	branch $3 ? label_6 : label_8
label_6:
	ret 1
label_8:
	$4 = read i32 @ $n_ptr
	$5 = math sub i32 $4, 1
	$6 = call fibonacci($5)
	$7 = read i32 @ $n_ptr
	$8 = math sub i32 $7, 2
	$9 = call fibonacci($8)
	$10 = math add i32 $6, $9
	ret $10
}

define i32 add_multiply(i32 $a, i32 $b, i32 $c) {
entry:
	; bind parameter: a
	$a_ptr = stack_alloc i32
	write i32 $a @ $a_ptr
	; bind parameter: b
	$b_ptr = stack_alloc i32
	write i32 $b @ $b_ptr
	; bind parameter: c
	$c_ptr = stack_alloc i32
	write i32 $c @ $c_ptr
	$0 = read i32 @ $a_ptr
	$1 = read i32 @ $b_ptr
	$2 = math add i32 $0, $1
	$3 = read i32 @ $c_ptr
	$4 = math mul i32 $2, $3
	ret $4
}

define i32 max_value(i32 $a, i32 $b) {
entry:
	; bind parameter: a
	$a_ptr = stack_alloc i32
	write i32 $a @ $a_ptr
	; bind parameter: b
	$b_ptr = stack_alloc i32
	write i32 $b @ $b_ptr
	; if condition
	$0 = read i32 @ $a_ptr
	$1 = read i32 @ $b_ptr
	$2 = cmp sgt i32 $0, $1
	branch $2 ? label_9 : label_11
label_9:
	$3 = read i32 @ $a_ptr
	ret $3
label_11:
	$4 = read i32 @ $b_ptr
	ret $4
}

define void main() {
entry:
	call print(120)
	call print(3628800)
	call print(55)
	call print(20)
	call print(42)
	call print(40320)
	ret
}