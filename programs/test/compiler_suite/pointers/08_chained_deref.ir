define i32 @chained_deref_assign(i32 $val) {
@entry:
	; bind parameter: val
	$val_ptr = stack_alloc i32
	store i32 $val -> $val_ptr
	; local var: ptr
	$ptr = stack_alloc i32*
	$0 = heap_alloc i32
	store i32* $0 -> $ptr
	; local var: pp
	$pp = stack_alloc i32**
	store i32** $ptr -> $pp
	; assignment
	$1 = load i32 $val_ptr
	$2 = math add i32 $1, 1
	$3 = load i32** $pp
	$4 = load i32* $3
	store i32 $2 -> $4
	$5 = load i32* $ptr
	; defer: captured call @free with 1 args
	$6 = load i32* $ptr
	$7 = load i32 $6
	; executing deferred cleanup before return
	$8 = call @free($5)
	ret $7
}
