define i32 chained_deref_assign(i32 $val) {
entry:
	; bind parameter: val
	$val_ptr = stack_alloc i32
	write i32 $val @ $val_ptr
	; local var: ptr
	$ptr = stack_alloc i32*
	$0 = heap_alloc i32
	write i32* $0 @ $ptr
	; local var: pp
	$pp = stack_alloc i32**
	write i32** $ptr @ $pp
	; assignment
	$1 = read i32 @ $val_ptr
	$2 = math add i32 $1, 1
	$3 = read i32** @ $pp
	$4 = read i32* @ $3
	write i32 $2 @ $4
	$5 = read i32* @ $ptr
	; defer: captured call free with 1 args
	$6 = read i32* @ $ptr
	$7 = read i32 @ $6
	; executing deferred cleanup before return
	call free($5)
	ret $7
}