type Point = {x: f32, y: f32}

define f32 calc_offset(Point* $p, f32 $shift) {
entry:
	; bind parameter: p
	$p_ptr = stack_alloc Point*
	write Point* $p @ $p_ptr
	; bind parameter: shift
	$shift_ptr = stack_alloc f32
	write f32 $shift @ $shift_ptr
	; assignment
	$0 = read {x: f32, y: f32}* @ $p_ptr
	$1 = offset f32 $0, 0
	$2 = read {x: f32, y: f32}* @ $p_ptr
	$3 = offset f32 $2, 0
	$4 = read f32 @ $3
	$5 = read f32 @ $shift_ptr
	$6 = math add f32 $4, $5
	write f32 $6 @ $1
	; assignment
	$7 = read {x: f32, y: f32}* @ $p_ptr
	$8 = offset f32 $7, 4
	$9 = read {x: f32, y: f32}* @ $p_ptr
	$10 = offset f32 $9, 4
	$11 = read f32 @ $10
	$12 = read f32 @ $shift_ptr
	$13 = math add f32 $11, $12
	write f32 $13 @ $8
	$14 = read {x: f32, y: f32}* @ $p_ptr
	$15 = offset f32 $14, 0
	$16 = read f32 @ $15
	$17 = read {x: f32, y: f32}* @ $p_ptr
	$18 = offset f32 $17, 4
	$19 = read f32 @ $18
	$20 = math mul f32 $16, $19
	ret $20
}