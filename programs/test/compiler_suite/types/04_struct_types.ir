type Point = {x: f32, y: f32}

define f32 calc_offset(Point* $p, f32 $shift) {
entry:
	; bind parameter: p
	$p_ptr = stack_alloc Point*
	write Point* $p @ $p_ptr
	; bind parameter: shift
	$shift_ptr = stack_alloc f32
	write f32 $shift @ $shift_ptr
	; assignment
	$0 = read {x: f32, y: f32}* @ $p_ptr
	; Address of field 'x' at offset 0
	$1 = offset f32 $0, 0
	$2 = read {x: f32, y: f32}* @ $p_ptr
	; Access field 'x' at offset 0
	$3 = read f32 @ $2 + 0
	$4 = read f32 @ $shift_ptr
	$5 = math add f32 $3, $4
	write f32 $5 @ $1
	; assignment
	$6 = read {x: f32, y: f32}* @ $p_ptr
	; Address of field 'y' at offset 4
	$7 = offset f32 $6, 4
	$8 = read {x: f32, y: f32}* @ $p_ptr
	; Access field 'y' at offset 4
	$9 = read f32 @ $8 + 4
	$10 = read f32 @ $shift_ptr
	$11 = math add f32 $9, $10
	write f32 $11 @ $7
	$12 = read {x: f32, y: f32}* @ $p_ptr
	; Access field 'x' at offset 0
	$13 = read f32 @ $12 + 0
	$14 = read {x: f32, y: f32}* @ $p_ptr
	; Access field 'y' at offset 4
	$15 = read f32 @ $14 + 4
	$16 = math mul f32 $13, $15
	ret $16
}