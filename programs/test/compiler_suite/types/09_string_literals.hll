; Test string literal compilation to inline structs
; String literals should compile to { data: u8*, length: u64 } structs

main: () -> i32 {
    ; Declare variables with type annotations and assign string literals
    str1: { data: u8*, length: u64 } = "Hello World"

    ; String with escape sequences
    str2: { data: u8*, length: u64 } = "Line 1\nLine 2\tTabbed"

    ; Empty string
    str3: { data: u8*, length: u64 } = ""

    return 0;
}
