; Ensure generic specializations use collision-free names in IR.
struct Box<T> {
    value: T
}

struct Box_i32 {
    value: i32
}

main: () -> i32 {
    boxed: Box<i32>* = new(Box<i32>)
    legacy: Box_i32* = new(Box_i32)
    double: Box<Box<i32>>* = new(Box<Box<i32>>)
    free(boxed)
    free(legacy)
    free(double)
    return 0
}
