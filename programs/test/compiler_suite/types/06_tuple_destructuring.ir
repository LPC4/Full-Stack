define {i32, i32} @divide(i32 $a, i32 $b) {
@entry:
	; bind parameter: a
	$a_ptr = stack_alloc i32
	store i32 $a -> $a_ptr
	; bind parameter: b
	$b_ptr = stack_alloc i32
	store i32 $b -> $b_ptr
	$0 = load i32 $a_ptr
	$1 = load i32 $b_ptr
	$2 = math sdiv i32 $0, $1
	$3 = load i32 $a_ptr
	$4 = load i32 $b_ptr
	$5 = math mod i32 $3, $4
	$6 = stack_alloc {i32, i32}
	store i32 $2 -> $6 + 0
	store i32 $5 -> $6 + 4
	ret $6
}

define i32 @test_tuple_destructuring() {
@entry:
	; assignment
	$0 = call @divide(10, 3)
	$1 = load i32 $0 + 0
	; local var (from tuple destructure): q
	$q = stack_alloc i32
	store i32 $1 -> $q
	$2 = load i32 $0 + 4
	; local var (from tuple destructure): r
	$r = stack_alloc i32
	store i32 $2 -> $r
	$3 = load i32 $q
	ret $3
}
