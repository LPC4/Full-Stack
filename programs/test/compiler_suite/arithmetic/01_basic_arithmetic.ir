define i32 @main() {
@entry:
	; local var: a
	$a = stack_alloc i32
	write i32 10 @ $a
	; local var: b
	$b = stack_alloc i32
	write i32 20 @ $b
	; local var: c
	$c = stack_alloc i32
	$0 = read i32 @ $a
	$1 = read i32 @ $b
	$2 = math add i32 $0, $1
	$3 = math mul i32 $2, 2
	write i32 $3 @ $c
	; local var: d
	$d = stack_alloc i32
	$4 = read i32 @ $c
	$5 = math sdiv i32 $4, 5
	$6 = read i32 @ $a
	$7 = read i32 @ $b
	$8 = math mod i32 $6, $7
	$9 = math sub i32 $5, $8
	write i32 $9 @ $d
	; local var: e
	$e = stack_alloc i32
	$10 = read i32 @ $d
	$11 = unary neg i32 $10
	write i32 $11 @ $e
	$12 = read i32 @ $e
	ret $12
}
