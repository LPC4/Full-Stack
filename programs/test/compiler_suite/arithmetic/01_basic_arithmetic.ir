define i32 @main() {
@entry:
	; local var: a
	$a = stack_alloc i32
	store i32 10 -> $a
	; local var: b
	$b = stack_alloc i32
	store i32 20 -> $b
	; local var: c
	$c = stack_alloc i32
	$0 = load i32 $a
	$1 = load i32 $b
	$2 = math add i32 $0, $1
	$3 = math mul i32 $2, 2
	store i32 $3 -> $c
	; local var: d
	$d = stack_alloc i32
	$4 = load i32 $c
	$5 = math sdiv i32 $4, 5
	$6 = load i32 $a
	$7 = load i32 $b
	$8 = math mod i32 $6, $7
	$9 = math sub i32 $5, $8
	store i32 $9 -> $d
	; local var: e
	$e = stack_alloc i32
	$10 = load i32 $d
	$11 = unary neg i32 $10
	store i32 $11 -> $e
	$12 = load i32 $e
	ret $12
}
