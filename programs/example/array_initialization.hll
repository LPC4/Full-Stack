; Array literal demo: stack values mirrored into a heap array.
main: () -> i32 {
    source: i32[4] = [3, 5, 7, 11]

    mirror: i32[4]* = new([4]i32)
    defer free(mirror)
    @mirror = [3, 5, 7, 11]

    total: i32 = @source[0] + @source[1] + @source[2] + @source[3]
    return total + @mirror[1]
}



