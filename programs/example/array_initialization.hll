; Array literal demo: stack values mirrored into a heap array.
main: () -> i32 {
    source: i32[4] = [3, 5, 7, 11]

    mirror: i32* = new(i32, 4)
    defer free(mirror)
    @mirror[0] = 3
    @mirror[1] = 5
    @mirror[2] = 7
    @mirror[3] = 11

    total: i32 = @source[0] + @source[1] + @source[2] + @source[3]
    ; Exit 0 on success by subtracting the expected combined total.
    return total + @mirror[1] - 31
}



