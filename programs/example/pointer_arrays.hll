; Pointers: address-of, dereference, and heap cleanup.
main: () -> i32 {
    left: i32 = 8
    right: i32 = 21

    pl: i32* = &left
    pr: i32* = &right

    @pl = @pl + 1
    @pr = @pr + 2

    heap: i32* = new(i32)
    defer free(heap)
    @heap = @pl + @pr

    ; Exit 0 on success by subtracting the expected heap sum.
    return @heap - 32
}


