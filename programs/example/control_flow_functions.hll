; Control flow example: functions, if/else, while, and defer.
countdown: (n: i32) -> i32 {
    total: i32 = 0
    while n > 0 {
        total = total + n
        n = n - 1
    }
    return total
}

main: () -> i32 {
    ptr: i32* = new(i32)
    defer free(ptr)

    result: i32 = countdown(4)
    @ptr = result

    if result > 5 {
        return result
    } else {
        return @ptr
    }
}

