; Control flow: loops, continue, and deferred cleanup.
accumulate_evens: (limit: i32) -> i32 {
    total: i32 = 0
    i: i32 = 0

    while i < limit {
        i = i + 1
        if i % 2 != 0 {
            continue
        }
        total = total + i
    }

    return total
}

main: () -> i32 {
    scratch: i32* = new(i32)
    defer free(scratch)

    score: i32 = accumulate_evens(10)
    @scratch = score

    if score != 30 {
        return 1
    }

    return @scratch + 12
}


